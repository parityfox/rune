{
  "name": "rune-editor",
  "version": "1.0.0",
  "description": "A lightweight, extensible rich text editor. Framework-agnostic, headless by design.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./react": "./adapters/react/index.js",
    "./web-component": "./adapters/web-component/rune-editor.js",
    "./styles": "./styles/rune.css",
    "./collab/*": "./collab/*",
    "./server/*": "./server/*"
  },
  "files": [
    "src/",
    "adapters/",
    "styles/",
    "rune.config.js",
    "collab/",
    "server/"
  ],
  "keywords": [
    "rich-text-editor",
    "rte",
    "wysiwyg",
    "contenteditable",
    "rune",
    "editor",
    "headless"
  ],
  "author": "ParityFox (https://parityfox.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parityfox/rune.git"
  },
  "homepage": "https://github.com/parityfox/rune#readme",
  "bugs": {
    "url": "https://github.com/parityfox/rune/issues"
  },
  "scripts": {
    "example": "npx serve . -p 4000",
    "build:demo": "esbuild examples/vendor-entry.js --bundle --format=esm --outfile=examples/vendor/collab-deps.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/collab-ime.mjs && node tests/e2e/collab-persistence.mjs && node tests/e2e/collab-suggestions.mjs",
    "collab-server": "node server/collab-server.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.3",
    "playwright-core": "^1.60.0",
    "vitest": "^4.0.18",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  }
}
