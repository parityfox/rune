{
  "name": "rune-editor",
  "version": "1.0.0",
  "description": "A lightweight, extensible rich text editor. Framework-agnostic, headless by design.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./react": "./adapters/react/index.js",
    "./web-component": "./adapters/web-component/rune-editor.js",
    "./styles": "./styles/rune.css"
  },
  "files": [
    "src/",
    "adapters/",
    "styles/",
    "rune.config.js"
  ],
  "keywords": [
    "rich-text-editor",
    "rte",
    "wysiwyg",
    "contenteditable",
    "rune",
    "editor",
    "headless"
  ],
  "author": "Vikramjeet Singh Sra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parityfox/rune.git"
  },
  "homepage": "https://github.com/parityfox/rune#readme",
  "bugs": {
    "url": "https://github.com/parityfox/rune/issues"
  },
  "scripts": {
    "example": "npx serve . -p 4000",
    "build:demo": "esbuild node_modules/yjs/dist/yjs.mjs --bundle --format=esm --outfile=examples/vendor/yjs.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.3",
    "vitest": "^4.0.18",
    "yjs": "^13.6.31"
  }
}
