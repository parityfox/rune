{
  "name": "@parityfox/rune-editor",
  "version": "1.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A lightweight, extensible rich text editor. Framework-agnostic, headless by design.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "default": "./adapters/react/index.js"
    },
    "./vue": {
      "types": "./types/vue.d.ts",
      "default": "./adapters/vue/index.js"
    },
    "./svelte": {
      "types": "./types/svelte.d.ts",
      "default": "./adapters/svelte/index.js"
    },
    "./web-component": {
      "types": "./types/web-component.d.ts",
      "default": "./adapters/web-component/rune-editor.js"
    },
    "./styles": "./styles/rune.css",
    "./collab": {
      "types": "./types/collab.d.ts",
      "default": "./collab/index.js"
    },
    "./collab/*": "./collab/*",
    "./server/*": "./server/*"
  },
  "files": [
    "src/",
    "adapters/",
    "styles/",
    "rune.config.js",
    "collab/",
    "server/",
    "assets/",
    "types/"
  ],
  "keywords": [
    "rich-text-editor",
    "rte",
    "wysiwyg",
    "contenteditable",
    "rune",
    "editor",
    "headless"
  ],
  "author": "ParityFox (https://parityfox.com)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parityfox/rune.git"
  },
  "homepage": "https://github.com/parityfox/rune#readme",
  "bugs": {
    "url": "https://github.com/parityfox/rune/issues"
  },
  "scripts": {
    "example": "npx serve . -p 4000",
    "build:demo": "esbuild examples/vendor-entry.js --bundle --format=esm --outfile=examples/vendor/collab-deps.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test",
    "test:e2e": "node tests/e2e/collab-ime.mjs && node tests/e2e/collab-persistence.mjs && node tests/e2e/collab-suggestions.mjs",
    "collab-server": "node server/collab-server.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.3",
    "playwright-core": "^1.60.0",
    "vitest": "^4.0.18",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "vue": ">=3.2",
    "svelte": ">=3",
    "ws": "^8.0.0",
    "y-indexeddb": "^9.0.0",
    "y-protocols": "^1.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "ws": {
      "optional": true
    },
    "y-indexeddb": {
      "optional": true
    },
    "y-protocols": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    },
    "yjs": {
      "optional": true
    }
  }
}
